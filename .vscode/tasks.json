{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "astro: dev",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^never matches$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "astro\\s+v\\d",
          "endsPattern": "watching for file changes"
        }
      }
    }
  ]
}
