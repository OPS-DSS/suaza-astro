---
import { AnalyticsPageContent } from './AnalyticsPageContent'
import type { ForestPlotDataRow, AnalyticsRow } from '@/lib/parquet'

interface Props {
  title: string
  text: string
  forestPlotData?: ForestPlotDataRow[]
  analyticsData?: AnalyticsRow[]
  csvUrl?: string
}

const { title, forestPlotData, analyticsData } = Astro.props
---

<div class="mx-auto max-w-[120em] px-2 sm:px-6 lg:px-10 mb-16">
  <div class="flex flex-col gap-2">
    <h1 class="text-3xl font-bold my-6">{title}</h1>
    <AnalyticsPageContent
      forestPlotData={forestPlotData}
      analyticsData={analyticsData}
      client:only="react"
    />
  </div>
</div>
