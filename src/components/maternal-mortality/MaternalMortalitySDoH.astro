---
import { maternalMortalityIndicators as indicators } from '@/lib/indicators'

const { title, text } = Astro.props

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/'

const dimensionLabels: Record<string, string> = {
  dss: 'Determinantes Sociales de la Salud',
  policy: 'Política',
}

const subdimensionsByDim: Record<string, string[]> = {}
for (const ind of indicators) {
  subdimensionsByDim[ind.dimension] ??= []
  for (const sub of ind.subdimensions) {
    if (!subdimensionsByDim[ind.dimension].includes(sub)) {
      subdimensionsByDim[ind.dimension].push(sub)
    }
  }
}
---

<div class="mx-auto max-w-7xl px-2 sm:px-6 lg:px-10">
  <div class="flex flex-col gap-2">
    <h1 class="text-3xl font-bold my-6">{title}</h1>
    <p class="text-gray-700">{text}</p>

    <div class="flex flex-col gap-3 mt-4">
      <div class="flex gap-3 items-center">
        <div
          class="flex rounded-lg border border-gray-300 overflow-hidden text-sm"
        >
          {
            Object.entries(dimensionLabels).map(([dim, label], i) => (
              <button
                data-dim-btn={dim}
                type="button"
                aria-pressed={i === 0 ? 'true' : 'false'}
                class={
                  i === 0
                    ? 'px-4 py-2 font-medium bg-gray-800 text-white transition-colors'
                    : 'px-4 py-2 font-medium bg-white text-gray-700 hover:bg-gray-50 transition-colors'
                }
              >
                {label}
              </button>
            ))
          }
        </div>
      </div>

      <div class="flex gap-3 items-start min-h-8">
        <div class="flex gap-2 flex-wrap">
          {
            Object.entries(subdimensionsByDim).map(([dim, subs]) => (
              <div data-subdim-group={dim} class="contents">
                {subs.map((sub) => (
                  <button
                    data-subdim-tag={sub}
                    data-subdim-dim={dim}
                    type="button"
                    aria-pressed="true"
                    class="px-3 py-1 rounded-full text-xs font-medium border transition-colors bg-blue-700 text-white border-blue-700 capitalize hidden"
                  >
                    {sub}
                  </button>
                ))}
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <ul id="indicators-list" class="mt-4 flex flex-col gap-4">
      {
        indicators.map((ind) => (
          <li
            data-dimension={ind.dimension}
            data-subdimensions={ind.subdimensions.join(',')}
          >
            <a
              href={`${base}${ind.slug}`}
              class="block rounded-lg border border-gray-200 p-4 hover:border-blue-400 hover:shadow-sm transition-all"
            >
              <h3 class="text-lg font-semibold text-gray-900">{ind.title}</h3>
              <p class="mt-1 text-sm text-gray-600">{ind.description}</p>
              <div class="mt-3 flex flex-wrap gap-2">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700 border border-gray-200">
                  {dimensionLabels[ind.dimension] ?? ind.dimension}
                </span>
                {ind.subdimensions.map((sub) => (
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700 border border-blue-200 capitalize">
                    {sub}
                  </span>
                ))}
              </div>
            </a>
          </li>
        ))
      }
    </ul>

    <p id="empty-message" class="text-gray-500 italic mt-4 hidden">
      No hay indicadores disponibles para los filtros seleccionados.
    </p>
  </div>
</div>
<script>
  function getInitialDimension(): string {
    const params = new URLSearchParams(window.location.search)
    const d = params.get('dimension')
    return d === 'dss' || d === 'policy' ? d : 'dss'
  }

  let selectedDimension = getInitialDimension()
  let selectedSubdimensions = new Set<string>()

  function getSubdimsForDimension(dim: string): string[] {
    return Array.from(
      document.querySelectorAll<HTMLButtonElement>(
        `[data-subdim-tag][data-subdim-dim="${dim}"]`,
      ),
    ).map((btn) => btn.getAttribute('data-subdim-tag')!)
  }

  function selectAllSubdims() {
    selectedSubdimensions = new Set(getSubdimsForDimension(selectedDimension))
  }

  function filterIndicators() {
    const items = document.querySelectorAll<HTMLLIElement>(
      '#indicators-list [data-dimension]',
    )
    let visible = 0

    items.forEach((item) => {
      const dim = item.getAttribute('data-dimension') ?? ''
      const subs = (item.getAttribute('data-subdimensions') ?? '')
        .split(',')
        .filter(Boolean)
      const dimMatch = dim === selectedDimension
      const subMatch = subs.some((s) => selectedSubdimensions.has(s))
      if (dimMatch && subMatch) {
        item.style.display = ''
        visible++
      } else {
        item.style.display = 'none'
      }
    })

    document
      .getElementById('empty-message')
      ?.classList.toggle('hidden', visible > 0)
  }

  function updateDimensionButtons() {
    document
      .querySelectorAll<HTMLButtonElement>('[data-dim-btn]')
      .forEach((btn) => {
        const dim = btn.getAttribute('data-dim-btn') ?? ''
        const active = dim === selectedDimension
        btn.setAttribute('aria-pressed', String(active))
        if (active) {
          btn.classList.add('bg-gray-800', 'text-white')
          btn.classList.remove('bg-white', 'text-gray-700', 'hover:bg-gray-50')
        } else {
          btn.classList.remove('bg-gray-800', 'text-white')
          btn.classList.add('bg-white', 'text-gray-700', 'hover:bg-gray-50')
        }
      })
  }

  function updateSubdimTags() {
    document
      .querySelectorAll<HTMLButtonElement>('[data-subdim-tag]')
      .forEach((btn) => {
        const dim = btn.getAttribute('data-subdim-dim') ?? ''
        const sub = btn.getAttribute('data-subdim-tag') ?? ''

        if (dim !== selectedDimension) {
          btn.classList.add('hidden')
          return
        }

        btn.classList.remove('hidden')
        const active = selectedSubdimensions.has(sub)
        btn.setAttribute('aria-pressed', String(active))
        if (active) {
          btn.classList.add('bg-blue-700', 'text-white', 'border-blue-700')
          btn.classList.remove('bg-white', 'text-blue-700', 'border-blue-200')
        } else {
          btn.classList.remove('bg-blue-700', 'text-white', 'border-blue-700')
          btn.classList.add('bg-white', 'text-blue-700', 'border-blue-200')
        }
      })
  }

  function setDimension(dim: string) {
    selectedDimension = dim
    selectAllSubdims()
    updateDimensionButtons()
    updateSubdimTags()
    filterIndicators()
    history.replaceState(null, '', `?dimension=${dim}`)
  }

  document
    .querySelectorAll<HTMLButtonElement>('[data-dim-btn]')
    .forEach((btn) => {
      btn.addEventListener('click', () => {
        const dim = btn.getAttribute('data-dim-btn')
        if (dim && dim in { dss: 1, policy: 1 }) setDimension(dim)
      })
    })

  document
    .querySelectorAll<HTMLButtonElement>('[data-subdim-tag]')
    .forEach((btn) => {
      btn.addEventListener('click', () => {
        const sub = btn.getAttribute('data-subdim-tag') ?? ''
        if (selectedSubdimensions.has(sub)) {
          selectedSubdimensions.delete(sub)
        } else {
          selectedSubdimensions.add(sub)
        }
        updateSubdimTags()
        filterIndicators()
      })
    })

  selectAllSubdims()
  updateDimensionButtons()
  updateSubdimTags()
  filterIndicators()
</script>
