---
import Layout from '@/layouts/Layout.astro'
import { buildStaticPaths } from '@/lib/pageFactory'
import { pageRegistry } from '@/lib/pageRegistry'
import type { PageProps } from '@/lib/pageRegistry'

export const getStaticPaths = buildStaticPaths

const props = Astro.props as PageProps
const { title, text, pages, slug, date } = props

const baseUrl = import.meta.env.BASE_URL
const entry = pageRegistry[slug ?? '']
const Component = entry?.component
const componentProps = entry?.resolveProps(props, baseUrl)
---

<Layout title={title} text={text} date={date} pages={pages} currentPage={slug}>
  {Component && <Component {...componentProps} />}
</Layout>
