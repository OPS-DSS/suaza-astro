---
import Layout from '../layouts/Layout.astro'
---

<Layout title="404 – Página no encontrada">
  <div class="min-h-screen flex items-center justify-center px-4 bg-white">
    <!-- Card -->
    <div
      class="w-full max-w-sm border border-stone-200 rounded-xl shadow-sm bg-white px-8 py-10 text-center"
    >
      <h1 class="text-base font-semibold text-stone-900 mb-1">
        No encontramos la página que buscas
      </h1>
      <p class="text-sm text-stone-500 leading-relaxed mb-6">
        La dirección no existe o ha sido movida.
      </p>

      <a
        href={import.meta.env.BASE_URL || '/'}
        class="inline-flex items-center justify-center gap-2 rounded-md border border-stone-200 bg-white hover:bg-stone-50 text-stone-900 text-sm font-medium px-4 py-2 transition-colors duration-150 shadow-xs"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M19 12H5M12 5l-7 7 7 7"></path>
        </svg>
        Volver al inicio
      </a>
    </div>
  </div>
</Layout>
